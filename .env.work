# Paper Assistant — work laptop config (Kiro)
# Copy to .env before use: cp .env.work .env

# Data directory (default: ~/.paper-assistant)
PAPER_ASSIST_DATA_DIR=./.paper-assistant

# No Anthropic API key needed — Kiro agent generates the summary directly.
# ANTHROPIC_API_KEY is only used by `paper-assist add` (calls summarizer.py),
# not by skill-import.

# TTS: edge-tts is free, no key needed. Uncomment to change voice.
# PAPER_ASSIST_TTS_VOICE=en-US-AriaNeural

# iCloud sync: disable on work laptop
PAPER_ASSIST_ICLOUD_SYNC=false

# Notion: disabled by default (no token on work laptop)
# PAPER_ASSIST_NOTION_SYNC_ENABLED=false

# qmd search: disabled by default (no qmd on work laptop)
# PAPER_ASSIST_QMD_ENABLED=false

# arXiv API: set a descriptive user-agent (recommended)
PAPER_ASSIST_ARXIV_USER_AGENT=paper-assistant/0.1
